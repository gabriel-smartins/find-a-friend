{
  "name": "06-find-friend-api",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "db:dev:up": "docker compose up -d",
    "db:dev:down": "docker compose down",
    "db:dev:logs": "docker compose logs -f postgres-db",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset",
    "test": "npm run db:test:up && npm run test:migrate && vitest run",
    "test:watch": "npm run db:test:up && npm run test:migrate && vitest",
    "test:clean": "npm run db:test:down",
    "db:test:up": "docker compose -f docker-compose.test.yml up -d",
    "db:test:down": "docker compose -f docker-compose.test.yml down",
    "test:migrate": "dotenv -e .env.test -- prisma migrate deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/node": "^24.8.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "prisma": "^6.17.1"
  },
  "imports": {
    "#use-cases/*": "./dist/use-cases/*.js",
    "#repositories/*": "./dist/repositories/*.js",
    "#controllers/*": "./dist/controllers/*.js",
    "#errors/*": "./dist/errors/*.js"
  }
}
