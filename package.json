{
  "name": "06-find-friend-api",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "db:dev:up": "docker compose up -d",
    "db:dev:down": "docker compose down",
    "db:dev:logs": "docker compose logs -f postgres-db",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test": "npm run db:test:up && npm run test:migrate && vitest run",
    "test:watch": "npm run db:test:up && npm run test:migrate && vitest",
    "test:clean": "npm run db:test:down",
    "db:test:up": "docker compose -f docker-compose.test.yml up -d",
    "db:test:down": "docker compose -f docker-compose.test.yml down",
    "test:migrate": "dotenv -e .env.test -- prisma migrate deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.8.0",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@fastify/jwt": "^10.0.0",
    "@prisma/client": "^6.17.1",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.17.1"
  },
  "imports": {
    "#use-cases/*": "./dist/use-cases/*.js",
    "#repositories/*": "./dist/repositories/*.js",
    "#controllers/*": "./dist/controllers/*.js",
    "#errors/*": "./dist/errors/*.js"
  }
}
